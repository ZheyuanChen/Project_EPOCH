begin:constant
  nel = 1.0e22
  intens = 1.0e22
  lambda = 1e-6
end:constant


begin:control
  nx = 128 
  ny = 128
  nparticles = nx * ny * 64
  nsteps = -1

  t_end = 100e-15

  # size of domain
  x_min = -3e-6
  x_max =  20e-6
  y_min = -10e-6
  y_max = -y_min

  dt_multiplier = 0.8
  stdout_frequency = 10
end:control


begin:qed
  use_qed = T 
  qed_start_time = 0 
  produce_photons = T 
  photon_energy_min = 50 * kev 
  produce_pairs = F 
  photon_dynamics = F 

end:qed


begin:collisions

  use_collisions = T
  coulomb_log = auto
  collide = all

end:collisions


begin:boundaries

  bc_x_min = simple_laser
  bc_x_max = open

  bc_y_max = periodic
  bc_y_min = periodic

end:boundaries


begin:species

  # electron
  name = Electron
  fraction = 0.5
  dump = T
  temperature = 0
  number_density = if (x gt -1e-6, nel * 1.0e6, 0)
  number_density_min = 1
  identify:electron

end:species


begin:species

  # ions
  name = Ion
  fraction = 0.5
  dump = T

  number_density = number_density(Electron)
  temperature = temperature_x(Electron)
  number_density_min = 1

  identify:proton

end:species


begin:species

  name = Photon
  nparticles = 0 # nparticles=0 since there are no initial photons in the system
  dump = T

  identify:photon

end:species


begin:species

  name = Positron
  nparticles = 0 # nparticles=0 since no initial positrons in the system
  dump = T
  identify:positron

end:species


begin:output_global

  force_final_to_be_restartable = F

end:output_global


begin:output

  name = normal

  # If use_offset_grid is true then the code dumps a grid which displays
  # positions relative to the left hand edge of the window
  use_offset_grid = F

  # number of timesteps between output dumps
  dt_snapshot = 100.0e-15 / 50

  # Properties at particle positions
  particles = never
  px = never
  py = never
  pz = never
  vx = never
  vy = never
  vz = never
  charge = never
  mass = never
  particle_weight = never
  species_id = never

  # Properties on grid
  grid = always
  ex = never
  ey = always
  ez = never
  bx = never
  by = never
  bz = never
  jx = never
  jy = never
  jz = never
  average_particle_energy = never
  mass_density = never + species
  charge_density = never
  number_density = never + species
  temperature = never + species
  poynt_flux = always
  distribution_functions = never
  ekbar = never +species

  absorption = always 
  total_energy_sum = always + species
  

end:output


begin:constant

  omega = 2.0 * pi * c / (1.0e-6)
  den_crit = critical(omega) # per cubic metre
  scale = 3.5e-6 # microns
  den_max = 5.0 * den_crit
  den_maxpoint = 40.0e-6 # microns
  den_contrast = 1.0

  amax = 1.0

end:constant


begin:laser

  boundary = x_min
  intensity = intens * 1.0e4
  omega = omega  
  polarisation = 0.0
  phase = 0.0
  t_profile = 1  # semigauss(time, amax, 0.1 * amax, t_wid)
  t_start = 0.0
  t_end = end
  profile = gauss(y, 0, 2.0 * micron)

end:laser

begin:laser

  boundary = x_min
  intensity = 2* intens * 1.0e4
  omega = omega  
  polarisation = 0.0
  phase = 0.0
  t_profile = 1  # semigauss(time, amax, 0.1 * amax, t_wid)
  t_start = 0.0
  t_end = end
  profile = gauss(y, 0, 2.0 * micron)

end:laser
