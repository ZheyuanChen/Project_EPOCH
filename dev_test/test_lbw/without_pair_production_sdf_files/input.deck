begin:control
   nx = 400
   ny = 400
   
   # 20um x 20um box
   x_min = -10e-6
   x_max = 10e-6
   y_min = -10e-6
   y_max = 10e-6
   
   t_end = 200e-15
   nsteps = -1
   stdout_frequency = 10
   dt_multiplier = 0.8
end:control

begin:boundaries

  bc_x_min = simple_laser
  bc_x_max = open

  bc_y_max = open
  bc_y_min = open

end:boundaries

begin:qed
   use_qed = T
   qed_start_time = 0
   produce_photons = T
   photon_energy_min = 50 * kev 

   
   photon_dynamics = T
   produce_pairs = F           # Required for any pair production
   
   # LBW specific settings from your source code
   linear_breit_wheeler = T
   LBW_differential_cross = T
   amplify_LBW_factor = 1000.0 # Boosts LBW so we see it on a laptop
   
   photon_energy_min = 0.5 * 1.6e-13 # 0.5 MeV threshold
end:qed

begin:collisions

  use_collisions = T
  coulomb_log = auto
  collide = all

end:collisions

begin:species
   name = electron
   identify:electron
   charge = -1.0
   mass = 1.0
   npart = 20 * 400 * 400 / 100 # Adjusting for laptop memory
   density_min = 0.0
   number_density = if(x gt 0.0 and x lt 5e-6, 1e27 * exp(-x/1e-6), 0.0)
end:species

begin:species
   name = photon
   identify:photon
   npart = 0
   dump = T
end:species

begin:species
   name = pos_lbw
   identify:bw_positron
   npart = 0
   dump = T
end:species

begin:species
   name = ele_lbw
   identify:bw_electron
   npart = 0
   dump = T
end:species

begin:laser
   boundary = x_min
   intensity = 1e27 # a0 ~ 200 at 800nm
   lambda = 0.8e-6
   pol_angle = 0.0
   
   # Gaussian profile in space and time
   profile = gauss(y, 0, 4e-6)
   t_profile = gauss(time, 40e-15, 20e-15)
end:laser

begin:output
   name = normal
   dt_snapshot = 200e-15/60
   use_offset_grid = F
   dt_average = 1e-18
   grid = always
   particles = never
   #species_counts = T
   ey = T
   bz = T
   number_density = always + species

end:output